<?xml version="1.0" encoding="UTF-8"?>
<component name="sideBarItem" extends="Group">
    <script type="text/brightscript" uri="pkg:/components/sideBarItem.brs" />
    <interface>
        <field id="itemContent" type="node" onChange = "dataChanged" />
        <field id="focusPercent" type="float" onChange="onFocusChanged" />
        <field id="listHasFocus" type="boolean" onChange="onFocusChanged" />
        <field id="itemHasFocus" type="boolean" onChange="onFocusChanged" />
    </interface>
    <children>
        <LayoutGroup id="layout"   layoutDirection="horizontal"  translation="[15,9]" itemSpacings="[20,0]">
        <Poster id="icon" width="40" height="40" translation="[0,0]"  />
        <Label id="label" height="40" width="280" font="font:SmallestSystemFont" translation="[0,5]" vertAlign="center" />
        
        </LayoutGroup>
    </children>
</component>    
